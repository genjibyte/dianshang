<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.ordertest.data.mapper.TestPaymentMapper">

    <delete id="deleteByOrderNo" parameterType="string">
        DELETE FROM t_payment WHERE order_no = #{orderNo}
    </delete>

    <select id="selectByOrderNo" parameterType="string" resultType="java.util.Map">
        SELECT * FROM t_payment WHERE order_no = #{orderNo}
    </select>

</mapper>
