<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.ordertest.data.mapper.TestOrderMapper">

    <delete id="deleteItemsByOrderNo" parameterType="string">
        DELETE FROM t_order_item WHERE order_no = #{orderNo}
    </delete>

    <delete id="deleteByOrderNo" parameterType="string">
        DELETE FROM t_order WHERE order_no = #{orderNo}
    </delete>

    <select id="selectByOrderNo" parameterType="string" resultType="java.util.Map">
        SELECT * FROM t_order WHERE order_no = #{orderNo}
    </select>

    <select id="countByUserId" parameterType="long" resultType="int">
        SELECT COUNT(*) FROM t_order WHERE user_id = #{userId}
    </select>

</mapper>
