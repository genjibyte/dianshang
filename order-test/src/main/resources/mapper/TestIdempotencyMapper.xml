<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.ordertest.data.mapper.TestIdempotencyMapper">

    <delete id="deleteByKey">
        DELETE FROM t_idempotency WHERE idempotency_key = #{key} AND biz_type = #{bizType}
    </delete>

    <delete id="deleteByBizId">
        DELETE FROM t_idempotency WHERE biz_id = #{bizId}
    </delete>

</mapper>
